# ── FRIDAY — .gitignore ───────────────────────────────────────────────────────

# !! NEVER push these !!
# ── API Keys & Secrets ────────────────────────────────────────────────────────
.env
.env.*
*.env
secrets.py
config.secret.*

# ── FRIDAY Database (contains your personal conversations & facts) ────────────
*.db
*.sqlite
*.sqlite3
friday_memory.db

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.whl
MANIFEST
pip-log.txt
pip-delete-this-directory.txt

# ── Virtual Environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env/
virtualenv/
.virtualenv/

# ── Node / React / Vite ───────────────────────────────────────────────────────
node_modules/
dist/
dist-ssr/
*.local
.vite/
.cache/

# ── Audio temp files (generated by edge-tts) ─────────────────────────────────
*.mp3
*.wav
*.ogg
temp_audio/
tmp_*.mp3

# ── Screenshots (saved by FRIDAY to desktop, not for repo) ───────────────────
FRIDAY_screenshot_*.png
screenshots/

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
*.log.*

# ── OS Files ──────────────────────────────────────────────────────────────────
# Windows
Thumbs.db
Thumbs.db:encdata
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Linux
*~
.fuse_hidden*
.directory
.Trash-*

# ── IDE / Editor ──────────────────────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates
*.swp
*.swo
*~
.project
.classpath
.settings/

# ── Pytest / Testing ──────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints
*.ipynb


models/
*.bin
*.pt
*.onnx
*.gguf
whisper_models/